# Apify API token (Console > Settings > Integrations)
APIFY_API_TOKEN=

# Optional: enables AI-model sentiment analysis. Set ONE of these two keys
# (or both, and use SENTIMENT_PROVIDER to pick). If neither is set, a
# lexicon-based fallback scorer is used instead.
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Optional: "anthropic", "deepseek", or "auto" (default). "auto" picks
# DeepSeek if DEEPSEEK_API_KEY is set, else Anthropic, else the fallback.
SENTIMENT_PROVIDER=auto

# GitHub Personal Access Token with 'repo' scope
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# The new/empty repo to push the dataset to, HTTPS form
GITHUB_REPO_URL=https://github.com/OWNER/REPO.git

# Branch to push to
GITHUB_BRANCH=main

# Local folder (inside this project) where CSV/JSON output is written
OUTPUT_DIR=data
